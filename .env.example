# Required
BOT_TOKEN=your_bot_token_from_botfather
# GROUP_ID = only this group receives forwards and can reply to users (bot ignores other groups)
GROUP_ID=your_telegram_group_id

# For production (e.g. Render) — webhook
WEBHOOK_BASE_URL=https://your-app.onrender.com
# Optional; default is reply-bot-webhook
# WEBHOOK_SECRET=my-secret-path

# Optional — Supabase for message threading
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=your_service_role_key

# Optional — customize messages
# WELCOME_MESSAGE=Send your full message in one message. Our admins will receive it and reply to you here. Once you send it, you must wait for an admin to reply before sending another message, so include everything at once. You can also edit your message before sending it.
# MESSAGE_AFTER=We'll get back to you soon.
# WAITING_MESSAGE=Waiting for admins to reply. You can only send another message after they've replied to your previous message.

# Optional — override local storage path when running multiple bot instances
# DATA_DIR=data-bot-2
